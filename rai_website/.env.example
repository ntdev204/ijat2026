# Database
POSTGRES_DB=rai_website
POSTGRES_USER=robot_admin
POSTGRES_PASSWORD=securepassword
DATABASE_URL=postgresql+asyncpg://robot_admin:securepassword@postgres:5432/rai_website

# Auth
JWT_SECRET=supersecretkey_change_in_production
JWT_ACCESS_EXPIRE_MIN=30
JWT_REFRESH_EXPIRE_DAYS=7
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123

# ZMQ (SCADA Bridge on RasPi)
# When running backend on a laptop, point SCADA to the RasPi/ROS2 host.
ZMQ_SCADA_HOST=100.120.77.81
ZMQ_SCADA_HOSTS=100.120.77.81
ZMQ_CAMERA_HOST=100.69.39.18
ZMQ_CMD_PORT=5555
ZMQ_TELEMETRY_PORT=5556
ZMQ_CAMERA_PORT=5557

# Jetson adaptive-context-aware API/result plane as seen from rai_website.
ADAPTIVE_API_URL=http://100.69.39.18:8080
ADAPTIVE_RESULT_HOST=100.69.39.18
ADAPTIVE_RESULT_PORT=5556
ADAPTIVE_RESULT_ENABLED=true
TRAINING_API_URL=http://host.docker.internal:8081

# Face authentication
FACE_MATCH_THRESHOLD=0.78
FACE_AUTH_SHARED_SECRET=
FACE_DATA_DIR=/app/data/faces
FACE_MIN_IMAGES=8
FACE_MAX_IMAGES=20

# Server-side sequence dataset labeling
DATASET_DATA_DIR=/app/data/datasets
OLLAMA_URL=http://host.docker.internal:11434
# Example vision model: llava, bakllava, or another Ollama multimodal model
OLLAMA_VLM_MODEL=
OLLAMA_LLM_MODEL=llama3.1

# SSH terminal bridge
SSH_ENABLED=false
SSH_LAPTOP_HOST=
SSH_LAPTOP_PORT=22
SSH_LAPTOP_USER=
SSH_RASPI_HOST=100.120.77.81
SSH_RASPI_PORT=22
SSH_RASPI_USER=rai
SSH_CONNECT_TIMEOUT_SEC=10

# Client -> rai_web_api (ROS2 FastAPI package, default launch port 8080)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_AUTH_ENABLED=false
NEXT_PUBLIC_CLIENT_LOGS_ENABLED=false
